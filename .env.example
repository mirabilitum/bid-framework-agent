# Rename this file to .env and fill in your API key.
# Only the provider you use needs to be configured.

# --- Claude (Anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- OpenAI ---
# OPENAI_API_KEY=sk-xxx

# --- Kimi (Moonshot) ---
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_API_BASE=https://api.moonshot.cn/v1
# OPENAI_COMPATIBLE_MODEL=moonshot-v1-128k

# --- DeepSeek ---
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_API_BASE=https://api.deepseek.com/v1
# OPENAI_COMPATIBLE_MODEL=deepseek-chat

# --- Gemini (Google, via OpenAI-compatible endpoint) ---
# OPENAI_COMPATIBLE_API_KEY=AIzaxxx
# OPENAI_COMPATIBLE_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_COMPATIBLE_MODEL=gemini-2.0-flash

# --- Ollama (local, no key needed) ---
# OPENAI_COMPATIBLE_API_BASE=http://localhost:11434/v1
# OPENAI_COMPATIBLE_MODEL=llama3

# --- Qwen (Alibaba) ---
# QWEN_API_KEY=sk-xxx
